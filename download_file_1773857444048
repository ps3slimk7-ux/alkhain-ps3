#-------------------------------------------------------------------------------
# Clear implicit built-in rules
#-------------------------------------------------------------------------------
.SUFFIXES:

ifeq ($(strip $(PSL1GHT)),)
$(error "Please set PSL1GHT in your environment. export PSL1GHT=<path>")
endif

#-------------------------------------------------------------------------------
# Game metadata
#-------------------------------------------------------------------------------
TITLE       :=  Among PS3
APPID       :=  AMNG00001
CONTENTID   :=  UP0001-$(APPID)_00-0000000000000000
ICON0       :=  ICON0.PNG
SFOXML      :=  sfo.xml

include $(PSL1GHT)/ppu_rules

#-------------------------------------------------------------------------------
# Build settings
#-------------------------------------------------------------------------------
TARGET      :=  game
BUILD       :=  build
SOURCES     :=  .
DATA        :=  .
INCLUDES    :=  .
PKGFILES    :=  .

#-------------------------------------------------------------------------------
# Libraries
#-------------------------------------------------------------------------------
LIBS        :=  -lgcm_sys -lio -lsysutil -lrt -llv2 -lsysmodule -lm

#-------------------------------------------------------------------------------
# Compiler flags
#-------------------------------------------------------------------------------
CFLAGS      =  -O2 -Wall -mcpu=cell $(MACHDEP) $(INCLUDE)
CXXFLAGS    =  $(CFLAGS)
LDFLAGS     =  $(MACHDEP)

#-------------------------------------------------------------------------------
# Files
#-------------------------------------------------------------------------------
CPPFILES    :=  main.cpp
OFILES      :=  main.o

#-------------------------------------------------------------------------------
# Build
#-------------------------------------------------------------------------------
all:
	$(PPU_CXX) $(CXXFLAGS) main.cpp -o $(TARGET).elf $(LIBS)

pkg:
	make_package_npdrm $(TARGET).elf PARAM.SFO ICON0.PNG $(TARGET).pkg

clean:
	rm -f *.o *.elf *.pkg